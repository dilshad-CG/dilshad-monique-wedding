# SPA routing for the wedding invitation when hosted in a sub-folder
# at https://clickgenius.co.za/wedding-invitation/
# Deep links such as /wedding-invitation/invite/abdul are served by index.html
# so React Router can render the personalised greeting.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /wedding-invitation/
  # Don't rewrite real files or directories (assets, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /wedding-invitation/index.html [L]
</IfModule>
