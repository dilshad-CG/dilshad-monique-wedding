# Wedding invitation hosted in a sub-folder:
# https://clickgenius.co.za/wedding-invitation/

# Serve index.html as the directory index (fixes 403 Forbidden on hosts
# whose default DirectoryIndex is index.php only).
DirectoryIndex index.html

# Allow access to this folder.
<IfModule mod_authz_core.c>
  Require all granted
</IfModule>

# Keep this private invitation out of search engines (applies to every
# file and SPA route in this folder).
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# SPA routing — deep links such as /wedding-invitation/invite/abdul are
# served by index.html so React Router can render the personalised greeting.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /wedding-invitation/
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /wedding-invitation/index.html [L]
</IfModule>
